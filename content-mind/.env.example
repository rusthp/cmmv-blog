# ContentMind — ProPlay News
# Copy to .env and fill in values

# cmmv-blog API (ProPlay News)
PROPLAY_API_URL=http://localhost:5000
PROPLAY_USERNAME=admin
PROPLAY_PASSWORD=your_admin_password_here

# Groq AI
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Scanner settings
REDDIT_POSTS_PER_GAME=5
YOUTUBE_VIDEOS_PER_GAME=5
SCAN_PERIOD=week

# Run settings
GAMES_PER_RUN=3
